---
import type { Lang } from '../i18n/utils';
import { localize } from '../i18n/utils';

interface Props {
  testimonial: {
    id: string;
    name: { en: string; my: string };
    text: { en: string; my: string };
    service: string;
    rating: number;
  };
  lang?: Lang;
}

const { testimonial, lang = 'en' } = Astro.props;
---

<div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow">
  <!-- Stars -->
  <div class="flex gap-1 mb-4">
    {Array.from({ length: testimonial.rating }).map(() => (
      <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <p class="text-charcoal/80 leading-relaxed mb-4 text-sm sm:text-base">
    "{localize(testimonial.text, lang)}"
  </p>

  <!-- Author -->
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-beige flex items-center justify-center text-gold font-semibold text-sm">
      {localize(testimonial.name, lang).charAt(0)}
    </div>
    <div>
      <div class="font-medium text-charcoal text-sm">{localize(testimonial.name, lang)}</div>
      <div class="text-xs text-muted">{testimonial.service}</div>
    </div>
  </div>
</div>
