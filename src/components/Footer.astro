---
import type { Lang } from '../i18n/utils';
import { useTranslations, localize } from '../i18n/utils';
import siteData from '../data/site.json';

interface Props {
  lang?: Lang;
}

const { lang = 'my' } = Astro.props;
const t = useTranslations(lang);

const prefix = lang === 'en' ? '/en' : '';
const navItems = [
  { key: 'nav.home', href: prefix || '/' },
  { key: 'nav.services', href: `${prefix}/services` },
  { key: 'nav.products', href: `${prefix}/products` },
  { key: 'nav.about', href: `${prefix}/about` },
  { key: 'nav.gallery', href: `${prefix}/gallery` },
  { key: 'nav.contact', href: `${prefix}/contact` },
];
---

<footer class="bg-charcoal text-white/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Salon Info -->
      <div>
        <h3 class="text-xl font-heading font-bold text-white mb-4">
          Salon One<span class="text-gold"> Dawei</span>
        </h3>
        <p class="text-sm leading-relaxed mb-4">{localize(siteData.address, lang)}</p>
        <p class="text-sm mb-1">{t('contact.phone')}: {siteData.phone}</p>
        <p class="text-sm">{siteData.email}</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          {lang === 'en' ? 'Quick Links' : 'အမြန်လင့်ခ်များ'}
        </h4>
        <nav class="space-y-2">
          {navItems.map(item => (
            <a href={item.href} class="block text-sm hover:text-gold transition-colors">
              {t(item.key)}
            </a>
          ))}
        </nav>
      </div>

      <!-- Hours & Social -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          {t('contact.hours')}
        </h4>
        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between">
            <span>{t('contact.weekdays')}</span>
            <span>{localize(siteData.hours.weekdays, lang)}</span>
          </div>
          <div class="flex justify-between">
            <span>{t('contact.saturday')}</span>
            <span>{localize(siteData.hours.saturday, lang)}</span>
          </div>
          <div class="flex justify-between">
            <span>{t('contact.sunday')}</span>
            <span>{localize(siteData.hours.sunday, lang)}</span>
          </div>
        </div>

        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t('footer.followUs')}
        </h4>
        <div class="flex gap-3">
          <a href={siteData.social.tiktok} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 hover:bg-gold flex items-center justify-center transition-colors" aria-label="TikTok">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.88c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.1a8.16 8.16 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.47z"/>
            </svg>
          </a>
          <a href={siteData.social.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/10 hover:bg-gold flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-white/10 text-center text-sm text-white/50">
      <p>&copy; {new Date().getFullYear()} {t('footer.copyright')}</p>
    </div>
  </div>
</footer>
