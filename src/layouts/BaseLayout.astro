---
import '../styles/global.css';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  isKiosk?: boolean;
}

const { title, description = 'Professional salon services in Dawei, Myanmar — hair, nails, skin care, and body treatments.', lang = 'en', isKiosk = false } = Astro.props;
const fullTitle = `${title} | Salon One Dawei`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Salon One Dawei" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Noto+Sans+Myanmar:wght@400;500;600;700&display=swap" rel="stylesheet" />

  {isKiosk && (
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Salon One Dawei" />
  )}
</head>
<body data-lang={lang} class:list={[{ 'kiosk-mode': isKiosk }]}>
  <slot />
</body>
</html>

<style is:global>
  .kiosk-mode {
    overscroll-behavior: none;
    -webkit-user-select: none;
    user-select: none;
  }
  .kiosk-mode button,
  .kiosk-mode a {
    min-width: 44px;
    min-height: 44px;
  }
</style>
