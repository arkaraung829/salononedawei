---
import PageLayout from '../../layouts/PageLayout.astro';
import TeamCard from '../../components/TeamCard.astro';
import { useTranslations } from '../../i18n/utils';
import teamData from '../../data/team.json';

const lang = 'en';
const t = useTranslations(lang);
---

<PageLayout title={t('nav.about')} lang={lang}>
  <!-- Header -->
  <section class="bg-beige py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-charcoal mb-3">
        {t('about.title')}
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        {t('about.subtitle')}
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-2xl sm:text-3xl font-heading font-bold text-charcoal mb-6">
          {t('about.story.title')}
        </h2>
        <p class="text-charcoal/70 text-lg leading-relaxed">
          {t('about.story.text')}
        </p>
      </div>

      <!-- Values -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-12">
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-charcoal mb-2">Expertise</h3>
          <p class="text-sm text-muted">Skilled professionals with years of training and experience.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-charcoal mb-2">Care</h3>
          <p class="text-sm text-muted">We treat every client like family, with personalized attention.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-gold/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-charcoal mb-2">Quality</h3>
          <p class="text-sm text-muted">Premium products and techniques for the best results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-heading font-bold text-charcoal text-center mb-12">
        {t('about.team.title')}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {teamData.members.map(member => (
          <TeamCard member={member} lang={lang} />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
