---
import PageLayout from '../layouts/PageLayout.astro';
import { useTranslations, localize } from '../i18n/utils';
import siteData from '../data/site.json';

const lang = 'my';
const t = useTranslations(lang);
---

<PageLayout title={t('nav.contact')} lang={lang}>
  <section class="bg-beige py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-charcoal mb-3">
        {t('contact.title')}
      </h1>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        {t('contact.subtitle')}
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        <div class="space-y-8">
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-charcoal mb-1">{t('contact.address')}</h3>
              <p class="text-muted">{localize(siteData.address, lang)}</p>
              <a href={`https://www.google.com/maps/search/?api=1&query=${siteData.coordinates.lat},${siteData.coordinates.lng}`} target="_blank" rel="noopener noreferrer" class="text-gold text-sm font-medium hover:underline mt-1 inline-block">
                {t('contact.getDirections')} &rarr;
              </a>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-charcoal mb-1">{t('contact.phone')}</h3>
              <p class="text-muted">{siteData.phone}</p>
              <p class="text-muted">{siteData.email}</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-charcoal mb-2">{t('contact.hours')}</h3>
              <div class="space-y-1.5 text-sm">
                <div class="flex justify-between gap-8">
                  <span class="text-muted">{t('contact.weekdays')}</span>
                  <span class="text-charcoal font-medium">{localize(siteData.hours.weekdays, lang)}</span>
                </div>
                <div class="flex justify-between gap-8">
                  <span class="text-muted">{t('contact.saturday')}</span>
                  <span class="text-charcoal font-medium">{localize(siteData.hours.saturday, lang)}</span>
                </div>
                <div class="flex justify-between gap-8">
                  <span class="text-muted">{t('contact.sunday')}</span>
                  <span class="text-charcoal font-medium">{localize(siteData.hours.sunday, lang)}</span>
                </div>
              </div>
            </div>
          </div>

          <a href={siteData.social.tiktok} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 bg-black hover:bg-charcoal text-white px-6 py-3 rounded-xl transition-colors font-medium">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.88-2.88 2.89 2.89 0 0 1 2.88-2.88c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.1a8.16 8.16 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.47z"/>
            </svg>
            Follow us on TikTok
          </a>
        </div>

        <div class="rounded-2xl overflow-hidden bg-beige h-80 lg:h-full min-h-[320px]">
          <iframe
            src={`https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d30000!2d${siteData.coordinates.lng}!3d${siteData.coordinates.lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTTCsDA0JzU2LjMiTiA5OMKwMTEnMjkuNCJF!5e0!3m2!1sen!2smm!4v1!5m2!1sen!2smm`}
            width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy"
            referrerpolicy="no-referrer-when-downgrade" title="Salon One Dawei Location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
